{
  "name": "pi-ralph-loop",
  "version": "1.0.0",
  "description": "Ralph Wiggum loop extension for pi — iterative task execution with fresh context windows",
  "type": "module",
  "keywords": [
    "pi-package",
    "ralph-loop",
    "ralph-wiggum"
  ],
  "license": "MIT",
  "scripts": {
    "test": "node --import tsx --test tests/**/*.test.ts",
    "test:live": "PI_RALPH_LIVE=1 node --import tsx --test tests/live-rpc.test.ts"
  },
  "peerDependencies": {
    "@mariozechner/pi-ai": "*",
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-tui": "*",
    "@sinclair/typebox": "*"
  },
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  },
  "devDependencies": {
    "@mariozechner/pi-ai": "^0.66.0",
    "@mariozechner/pi-coding-agent": "^0.66.0",
    "@mariozechner/pi-tui": "^0.66.0",
    "@sinclair/typebox": "^0.34.49",
    "@types/node": "^25.5.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
